# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://www.sriwanparts.com

# ─────────────────────────────────────────
# Database (Supabase PostgreSQL)
# ─────────────────────────────────────────
# Connection pooling URL (สำหรับ Prisma ทั่วไป)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (สำหรับ prisma migrate)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
DB_POOL_MAX="1"
DB_IDLE_TIMEOUT_MS="10000"
DB_CONNECTION_TIMEOUT_MS="15000"

# ─────────────────────────────────────────
# NextAuth.js
# ─────────────────────────────────────────
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel): NEXTAUTH_URL="https://www.sriwanparts.com"

# Optional seed admin user
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-this-to-a-strong-password"
SEED_ADMIN_NAME="ผู้ดูแลระบบ"

# ─────────────────────────────────────────
# Supabase Storage (สำหรับรูปสินค้า)
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Service role key สำหรับ server-side storage upload (bypass RLS) — ห้าม prefix NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# LINE OA Daily Summary
# Vercel Cron will send Authorization: Bearer <CRON_SECRET> to the route automatically.
CRON_SECRET="your-cron-secret"
LINE_MESSAGING_API_CHANNEL_ACCESS_TOKEN="your-line-channel-access-token"
LINE_MESSAGING_API_CHANNEL_SECRET="your-line-channel-secret"
# Comma-separated LINE user/group/room ids that should receive the daily summary.
# Used when target mode = ENV_IDS. When target mode = ADMIN_USERS the system will read mapped admin recipients from DB.
LINE_DAILY_SUMMARY_TO_IDS="Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Content approval + scheduled Facebook posting
APP_BASE_URL="https://www.sriwanparts.com"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-5.4-mini"
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="your-qstash-current-signing-key"
QSTASH_NEXT_SIGNING_KEY="your-qstash-next-signing-key"
FACEBOOK_PAGE_ID="your-facebook-page-id"
FACEBOOK_PAGE_ACCESS_TOKEN="your-facebook-page-access-token"
