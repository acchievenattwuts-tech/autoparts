{
  "name": "autoparts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "analyze": "set ANALYZE=true&& set NODE_OPTIONS=--max-old-space-size=4096&& next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "codex:skill:install": "node scripts/install-codex-skill.mjs",
    "codex:skill:install:seo-aio": "node scripts/install-codex-skill.mjs seo-aio",
    "codex:skill:install:all": "node scripts/install-codex-skill.mjs --all",
    "postinstall": "prisma generate",
    "seed": "npx tsx --env-file=.env.local prisma/seed.ts",
    "test:primary-transfer-roadmap": "tsx scripts/test-primary-transfer-roadmap.ts",
    "db:backup": "tsx --env-file=.env prisma/scripts/db-backup.ts",
    "db:restore": "tsx --env-file=.env prisma/scripts/db-restore.ts",
    "backfill:fact-profit": "tsx --env-file=.env prisma/scripts/backfill-fact-profit.ts"
  },
  "prisma": {
    "seed": "npx tsx --env-file=.env.local prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@supabase/supabase-js": "^2.100.0",
    "@upstash/qstash": "^2.10.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "promptpay-qr": "^0.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@prisma/client": "^7.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
