generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String           @id @default(cuid())
  name               String
  email              String           @unique
  password           String
  role               Role             @default(STAFF)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  appRoleId          String?
  mustChangePassword Boolean          @default(false)
  username           String?          @unique
  adjustments        Adjustment[]
  balanceForwards    BalanceForward[]
  creditNotes        CreditNote[]
  expenses           Expense[]
  purchases          Purchase[]
  purchaseReturns    PurchaseReturn[]
  receipts           Receipt[]
  sales              Sale[]
  appRole            AppRole?         @relation(fields: [appRoleId], references: [id])

  @@index([username])
  @@index([appRoleId])
}

model LoginThrottle {
  key            String    @id
  failures       Int       @default(0)
  firstFailureAt DateTime?
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AppRole {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  isSystem    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  permissions AppRolePermission[]
  users       User[]
}

model Permission {
  id          String              @id @default(cuid())
  key         String              @unique
  group       String
  label       String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  roles       AppRolePermission[]
}

model AppRolePermission {
  appRoleId    String
  permissionId String
  createdAt    DateTime   @default(now())
  appRole      AppRole    @relation(fields: [appRoleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([appRoleId, permissionId])
  @@index([permissionId])
}

model CarBrand {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  isActive  Boolean    @default(true)
  carModels CarModel[]
}

model CarModel {
  id         String            @id @default(cuid())
  name       String
  carBrandId String
  createdAt  DateTime          @default(now())
  isActive   Boolean           @default(true)
  carBrand   CarBrand          @relation(fields: [carBrandId], references: [id])
  products   ProductCarModel[]

  @@unique([name, carBrandId])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  isActive  Boolean   @default(true)
  slug      String?   @unique
  products  Product[]
}

model Supplier {
  id                String           @id @default(cuid())
  name              String           @unique
  contactName       String?
  phone             String?
  address           String?
  createdAt         DateTime         @default(now())
  code              String?          @unique
  isActive          Boolean          @default(true)
  preferredProducts Product[]        @relation("ProductPreferredSupplier")
  purchases         Purchase[]
  purchaseItems     PurchaseItem[]
  purchaseReturns   PurchaseReturn[]
  warrantyClaims    WarrantyClaim[]
}

model PartsBrand {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  isActive  Boolean   @default(true)
  products  Product[]
}

model Product {
  id                  String               @id @default(cuid())
  code                String               @unique
  name                String
  description         String?
  categoryId          String
  shelfLocation       String?
  costPrice           Decimal              @default(0) @db.Decimal(10, 2)
  salePrice           Decimal              @default(0) @db.Decimal(10, 2)
  stock               Int                  @default(0)
  minStock            Int                  @default(1)
  imageUrl            String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  purchaseUnitName    String               @default("ชิ้น")
  reportUnitName      String               @default("ชิ้น")
  saleUnitName        String               @default("ชิ้น")
  brandId             String?
  avgCost             Decimal              @default(0) @db.Decimal(10, 2)
  warrantyDays        Int                  @default(0)
  preferredSupplierId String?
  allowExpiredIssue   Boolean              @default(false)
  isLotControl        Boolean              @default(false)
  lotIssueMethod      LotIssueMethod       @default(FIFO)
  requireExpiryDate   Boolean              @default(false)
  slug                String?              @unique
  adjustmentItems     AdjustmentItem[]
  balanceForwards     BalanceForward[]
  creditNoteItems     CreditNoteItem[]
  lotBalances         LotBalance[]
  brand               PartsBrand?          @relation(fields: [brandId], references: [id])
  category            Category             @relation(fields: [categoryId], references: [id])
  preferredSupplier   Supplier?            @relation("ProductPreferredSupplier", fields: [preferredSupplierId], references: [id])
  aliases             ProductAlias[]
  carModels           ProductCarModel[]
  lots                ProductLot[]
  units               ProductUnit[]
  purchaseItems       PurchaseItem[]
  purchaseReturnItems PurchaseReturnItem[]
  saleItems           SaleItem[]
  stockCards          StockCard[]
  warranties          Warranty[]
}

model ProductUnit {
  id        String   @id @default(cuid())
  productId String
  name      String
  scale     Float
  isBase    Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
}

model ProductAlias {
  id        String   @id @default(cuid())
  productId String
  alias     String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, alias])
  @@index([alias])
}

model ProductCarModel {
  productId  String
  carModelId String
  carModel   CarModel @relation(fields: [carModelId], references: [id])
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, carModelId])
}

model StockCard {
  id           String             @id @default(cuid())
  productId    String
  docNo        String
  docDate      DateTime
  source       StockCardSource
  sorder       Int
  qtyIn        Decimal            @default(0) @db.Decimal(12, 4)
  qtyOut       Decimal            @default(0) @db.Decimal(12, 4)
  qtyBalance   Decimal            @default(0) @db.Decimal(12, 4)
  priceIn      Decimal            @default(0) @db.Decimal(10, 4)
  priceOut     Decimal            @default(0) @db.Decimal(10, 4)
  priceBalance Decimal            @default(0) @db.Decimal(10, 4)
  detail       String?
  referenceId  String?
  createdAt    DateTime           @default(now())
  landedCost   Decimal            @default(0) @db.Decimal(10, 2)
  product      Product            @relation(fields: [productId], references: [id])
  lotMovements StockMovementLot[]

  @@index([productId, docDate, sorder])
  @@index([docNo])
}

model BalanceForward {
  id              String    @id @default(cuid())
  docNo           String    @unique
  docDate         DateTime
  productId       String
  unitName        String
  qtyInBase       Decimal   @db.Decimal(12, 4)
  costPerBaseUnit Decimal   @db.Decimal(10, 4)
  note            String?
  status          DocStatus @default(ACTIVE)
  cancelledAt     DateTime?
  cancelNote      String?
  userId          String
  createdAt       DateTime  @default(now())
  product         Product   @relation(fields: [productId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([docDate])
}

model Purchase {
  id              String           @id @default(cuid())
  purchaseNo      String           @unique
  supplierId      String?
  userId          String
  totalAmount     Decimal          @db.Decimal(10, 2)
  discount        Decimal          @default(0) @db.Decimal(10, 2)
  netAmount       Decimal          @db.Decimal(10, 2)
  note            String?
  purchaseDate    DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  referenceNo     String?
  subtotalAmount  Decimal          @default(0) @db.Decimal(10, 2)
  vatAmount       Decimal          @default(0) @db.Decimal(10, 2)
  vatRate         Decimal          @default(0) @db.Decimal(5, 2)
  vatType         VatType          @default(NO_VAT)
  cancelNote      String?
  cancelledAt     DateTime?
  status          DocStatus        @default(ACTIVE)
  amountRemain    Decimal          @default(0) @db.Decimal(10, 2)
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  items           PurchaseItem[]
  purchaseReturns PurchaseReturn[]
}

model PurchaseItem {
  id             String            @id @default(cuid())
  purchaseId     String
  productId      String
  supplierId     String?
  quantity       Int
  costPrice      Decimal           @db.Decimal(10, 2)
  totalAmount    Decimal           @db.Decimal(10, 2)
  landedCost     Decimal           @default(0) @db.Decimal(10, 2)
  subtotalAmount Decimal           @default(0) @db.Decimal(10, 2)
  product        Product           @relation(fields: [productId], references: [id])
  purchase       Purchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  supplier       Supplier?         @relation(fields: [supplierId], references: [id])
  lotItems       PurchaseItemLot[]
}

model Customer {
  id              String       @id @default(cuid())
  code            String?      @unique
  name            String
  phone           String?
  address         String?
  taxId           String?
  note            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  shippingAddress String?
  isActive        Boolean      @default(true)
  creditNotes     CreditNote[]
  receipts        Receipt[]
  sales           Sale[]

  @@index([name])
}

model Sale {
  id              String          @id @default(cuid())
  saleNo          String          @unique
  customerName    String?
  customerPhone   String?
  userId          String
  totalAmount     Decimal         @db.Decimal(10, 2)
  discount        Decimal         @default(0) @db.Decimal(10, 2)
  netAmount       Decimal         @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?  @default(CASH)
  note            String?
  saleDate        DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  customerId      String?
  saleType        SaleType        @default(RETAIL)
  fulfillmentType FulfillmentType @default(PICKUP)
  shippingAddress String?
  shippingFee     Decimal?        @db.Decimal(10, 2)
  paymentType     SalePaymentType @default(CASH_SALE)
  subtotalAmount  Decimal         @default(0) @db.Decimal(10, 2)
  vatAmount       Decimal         @default(0) @db.Decimal(10, 2)
  vatRate         Decimal         @default(0) @db.Decimal(5, 2)
  vatType         VatType         @default(NO_VAT)
  cancelNote      String?
  cancelledAt     DateTime?
  status          DocStatus       @default(ACTIVE)
  amountRemain    Decimal         @default(0) @db.Decimal(10, 2)
  shippingMethod  ShippingMethod  @default(NONE)
  shippingStatus  ShippingStatus  @default(PENDING)
  trackingNo      String?
  creditNotes     CreditNote[]
  receipts        ReceiptItem[]
  customer        Customer?       @relation(fields: [customerId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  items           SaleItem[]
  warranties      Warranty[]
}

model SaleItem {
  id             String        @id @default(cuid())
  saleId         String
  productId      String
  quantity       Int
  salePrice      Decimal       @db.Decimal(10, 2)
  costPrice      Decimal       @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  subtotalAmount Decimal       @default(0) @db.Decimal(10, 2)
  warrantyDays   Int           @default(0)
  supplierId     String?
  supplierName   String?
  product        Product       @relation(fields: [productId], references: [id])
  sale           Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  lotItems       SaleItemLot[]
  warranties     Warranty[]
}

model Warranty {
  id           String          @id @default(cuid())
  saleId       String
  saleItemId   String
  productId    String
  startDate    DateTime
  endDate      DateTime
  note         String?
  createdAt    DateTime        @default(now())
  warrantyDays Int
  unitSeq      Int             @default(1)
  product      Product         @relation(fields: [productId], references: [id])
  sale         Sale            @relation(fields: [saleId], references: [id])
  saleItem     SaleItem        @relation(fields: [saleItemId], references: [id])
  claims       WarrantyClaim[]

  @@unique([saleItemId, unitSeq])
  @@index([productId])
  @@index([endDate])
}

model WarrantyClaim {
  id              String              @id @default(cuid())
  claimNo         String              @unique
  warrantyId      String
  claimDate       DateTime
  claimType       ClaimType
  status          WarrantyClaimStatus @default(DRAFT)
  outcome         ClaimOutcome?
  symptom         String?
  note            String?
  supplierId      String?
  supplierName    String?
  supplierPhone   String?
  supplierAddress String?
  sentAt          DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  supplier        Supplier?           @relation(fields: [supplierId], references: [id])
  warranty        Warranty            @relation(fields: [warrantyId], references: [id])

  @@index([warrantyId])
  @@index([claimDate])
  @@index([status])
}

model ExpenseCode {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  items       ExpenseItem[]
}

model Expense {
  id             String        @id @default(cuid())
  userId         String
  expenseDate    DateTime
  note           String?
  createdAt      DateTime      @default(now())
  subtotalAmount Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(10, 2)
  vatRate        Decimal       @default(0) @db.Decimal(5, 2)
  vatType        VatType       @default(NO_VAT)
  cancelNote     String?
  cancelledAt    DateTime?
  expenseNo      String        @unique
  netAmount      Decimal       @db.Decimal(10, 2)
  status         DocStatus     @default(ACTIVE)
  totalAmount    Decimal       @db.Decimal(10, 2)
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  items          ExpenseItem[]
}

model ExpenseItem {
  id            String      @id @default(cuid())
  expenseId     String
  expenseCodeId String
  description   String?
  amount        Decimal     @db.Decimal(10, 2)
  expenseCode   ExpenseCode @relation(fields: [expenseCodeId], references: [id])
  expense       Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model Adjustment {
  id          String           @id @default(cuid())
  adjustNo    String           @unique
  adjustDate  DateTime         @default(now())
  userId      String
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  cancelNote  String?
  cancelledAt DateTime?
  status      DocStatus        @default(ACTIVE)
  user        User             @relation(fields: [userId], references: [id])
  items       AdjustmentItem[]
}

model AdjustmentItem {
  id           String     @id @default(cuid())
  adjustmentId String
  productId    String
  qtyAdjust    Decimal    @db.Decimal(12, 4)
  reason       String?
  adjustment   Adjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])
}

model CreditNote {
  id             String           @id @default(cuid())
  cnNo           String           @unique
  cnDate         DateTime         @default(now())
  saleId         String?
  customerName   String?
  customerPhone  String?
  userId         String
  type           CreditNoteType
  totalAmount    Decimal          @db.Decimal(10, 2)
  note           String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  settlementType CNSettlementType @default(CASH_REFUND)
  refundMethod   CNRefundMethod?
  subtotalAmount Decimal          @default(0) @db.Decimal(10, 2)
  vatAmount      Decimal          @default(0) @db.Decimal(10, 2)
  vatRate        Decimal          @default(0) @db.Decimal(5, 2)
  vatType        VatType          @default(NO_VAT)
  customerId     String?
  cancelNote     String?
  cancelledAt    DateTime?
  status         DocStatus        @default(ACTIVE)
  amountRemain   Decimal          @default(0) @db.Decimal(10, 2)
  customer       Customer?        @relation(fields: [customerId], references: [id])
  sale           Sale?            @relation(fields: [saleId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
  items          CreditNoteItem[]
  receiptItems   ReceiptItem[]
}

model CreditNoteItem {
  id             String              @id @default(cuid())
  creditNoteId   String
  productId      String?
  qty            Decimal             @default(0) @db.Decimal(12, 4)
  unitPrice      Decimal             @default(0) @db.Decimal(10, 2)
  amount         Decimal             @default(0) @db.Decimal(10, 2)
  detail         String?
  subtotalAmount Decimal             @default(0) @db.Decimal(10, 2)
  creditNote     CreditNote          @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product        Product?            @relation(fields: [productId], references: [id])
  lotItems       CreditNoteItemLot[]
}

model PurchaseReturn {
  id             String               @id @default(cuid())
  returnNo       String               @unique
  returnDate     DateTime             @default(now())
  purchaseId     String?
  supplierId     String?
  userId         String
  totalAmount    Decimal              @db.Decimal(10, 2)
  note           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  subtotalAmount Decimal              @default(0) @db.Decimal(10, 2)
  vatAmount      Decimal              @default(0) @db.Decimal(10, 2)
  vatRate        Decimal              @default(0) @db.Decimal(5, 2)
  vatType        VatType              @default(NO_VAT)
  cancelNote     String?
  cancelledAt    DateTime?
  status         DocStatus            @default(ACTIVE)
  purchase       Purchase?            @relation(fields: [purchaseId], references: [id])
  supplier       Supplier?            @relation(fields: [supplierId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])
  items          PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id               String                  @id @default(cuid())
  purchaseReturnId String
  productId        String
  qty              Decimal                 @db.Decimal(12, 4)
  costPrice        Decimal                 @db.Decimal(10, 2)
  amount           Decimal                 @db.Decimal(10, 2)
  detail           String?
  subtotalAmount   Decimal                 @default(0) @db.Decimal(10, 2)
  product          Product                 @relation(fields: [productId], references: [id])
  purchaseReturn   PurchaseReturn          @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  lotItems         PurchaseReturnItemLot[]
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model StorefrontVisitDaily {
  id         String   @id @default(cuid())
  visitorKey String
  visitDay   String
  entryPath  String
  lastPath   String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt

  @@unique([visitorKey, visitDay])
  @@index([visitDay])
  @@index([lastSeenAt])
}

model Receipt {
  id            String        @id @default(cuid())
  receiptNo     String        @unique
  receiptDate   DateTime      @default(now())
  customerId    String?
  customerName  String?
  userId        String
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cancelNote    String?
  cancelledAt   DateTime?
  status        DocStatus     @default(ACTIVE)
  customer      Customer?     @relation(fields: [customerId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  items         ReceiptItem[]
}

model ReceiptItem {
  id         String      @id @default(cuid())
  receiptId  String
  saleId     String?
  paidAmount Decimal     @db.Decimal(10, 2)
  cnId       String?
  creditNote CreditNote? @relation(fields: [cnId], references: [id])
  receipt    Receipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  sale       Sale?       @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@index([cnId])
}

model ProductLot {
  id             String    @id @default(cuid())
  productId      String
  lotNo          String
  purchaseItemId String?
  mfgDate        DateTime?
  expDate        DateTime?
  unitCost       Decimal   @db.Decimal(10, 4)
  createdAt      DateTime  @default(now())
  product        Product   @relation(fields: [productId], references: [id])

  @@unique([productId, lotNo])
  @@index([productId, expDate])
}

model LotBalance {
  id        String  @id @default(cuid())
  productId String
  lotNo     String
  qtyOnHand Decimal @default(0) @db.Decimal(12, 4)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([productId, lotNo])
  @@index([productId])
}

model StockMovementLot {
  id          String    @id @default(cuid())
  stockCardId String
  lotNo       String
  qtyIn       Decimal   @default(0) @db.Decimal(12, 4)
  qtyOut      Decimal   @default(0) @db.Decimal(12, 4)
  unitCost    Decimal   @default(0) @db.Decimal(10, 4)
  stockCard   StockCard @relation(fields: [stockCardId], references: [id], onDelete: Cascade)

  @@index([stockCardId])
  @@index([lotNo])
}

model PurchaseItemLot {
  id             String       @id @default(cuid())
  purchaseItemId String
  lotNo          String
  qty            Decimal      @db.Decimal(12, 4)
  unitCost       Decimal      @db.Decimal(10, 4)
  mfgDate        DateTime?
  expDate        DateTime?
  purchaseItem   PurchaseItem @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)

  @@index([purchaseItemId])
}

model SaleItemLot {
  id         String   @id @default(cuid())
  saleItemId String
  lotNo      String
  qty        Decimal  @db.Decimal(12, 4)
  unitCost   Decimal  @db.Decimal(10, 4)
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)

  @@index([saleItemId])
}

model PurchaseReturnItemLot {
  id                   String             @id @default(cuid())
  purchaseReturnItemId String
  lotNo                String
  qty                  Decimal            @db.Decimal(12, 4)
  purchaseReturnItem   PurchaseReturnItem @relation(fields: [purchaseReturnItemId], references: [id], onDelete: Cascade)

  @@index([purchaseReturnItemId])
}

model CreditNoteItemLot {
  id               String         @id @default(cuid())
  creditNoteItemId String
  lotNo            String
  qty              Decimal        @db.Decimal(12, 4)
  isReturnLot      Boolean        @default(false)
  creditNoteItem   CreditNoteItem @relation(fields: [creditNoteItemId], references: [id], onDelete: Cascade)

  @@index([creditNoteItemId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model product_search_documents {
  product_id          String                  @id
  is_active           Boolean
  product_code        String
  product_name        String
  product_description String                  @default("")
  category_name       String                  @default("")
  brand_name          String                  @default("")
  alias_text          String                  @default("")
  car_brand_text      String                  @default("")
  car_model_text      String                  @default("")
  fitment_text        String                  @default("")
  search_text         String                  @default("")
  search_document     Unsupported("tsvector")
  product_created_at  DateTime                @db.Timestamptz(6)
  updated_at          DateTime                @default(now()) @db.Timestamptz(6)

  @@index([product_created_at(sort: Desc)], map: "idx_product_search_documents_created_at")
  @@index([search_document], map: "idx_product_search_documents_document", type: Gin)
  @@index([is_active], map: "idx_product_search_documents_is_active")
  @@index([search_text(ops: raw("gin_trgm_ops"))], map: "idx_product_search_documents_text_trgm", type: Gin)
}

enum Role {
  ADMIN
  STAFF
}

enum StockCardSource {
  BF
  PURCHASE
  SALE
  RETURN_IN
  ADJUST_IN
  ADJUST_OUT
  RETURN_OUT
