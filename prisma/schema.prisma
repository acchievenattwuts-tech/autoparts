generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Auth
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales           Sale[]
  purchases       Purchase[]
  expenses        Expense[]
  adjustments     Adjustment[]
  creditNotes     CreditNote[]
  purchaseReturns PurchaseReturn[]
}

enum Role {
  ADMIN
  STAFF
}

// ─────────────────────────────────────────
// Car / Category Master Data
// ─────────────────────────────────────────

model CarBrand {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  carModels CarModel[]
}

model CarModel {
  id         String    @id @default(cuid())
  name       String
  carBrandId String
  carBrand   CarBrand  @relation(fields: [carBrandId], references: [id])
  createdAt  DateTime  @default(now())
  products   ProductCarModel[]

  @@unique([name, carBrandId])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Supplier {
  id           String         @id @default(cuid())
  name         String         @unique
  contactName  String?
  phone        String?
  address      String?
  createdAt    DateTime       @default(now())
  purchases       Purchase[]
  purchaseItems   PurchaseItem[]
  purchaseReturns PurchaseReturn[]
}

// ─────────────────────────────────────────
// Parts Brand Master
// ─────────────────────────────────────────

model PartsBrand {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

// ─────────────────────────────────────────
// Product
// ─────────────────────────────────────────

model Product {
  id               String      @id @default(cuid())
  code             String      @unique
  name             String
  description      String?
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])
  brandId          String?
  brand            PartsBrand? @relation(fields: [brandId], references: [id])
  shelfLocation    String?
  costPrice        Decimal  @default(0) @db.Decimal(10, 2)
  salePrice        Decimal  @default(0) @db.Decimal(10, 2)
  stock            Int      @default(0)   // ระบบจัดการเท่านั้น ไม่ให้ user ระบุ
  avgCost          Decimal  @default(0) @db.Decimal(10, 2) // ต้นทุนถั่วเฉลี่ยปัจจุบัน — อัปเดตทุกครั้งที่ PURCHASE_IN
  minStock         Int      @default(1)
  // หน่วยนับ — ระบุชื่อหน่วยที่ใช้ในแต่ละบริบท (ต้องตรงกับ ProductUnit.name ของสินค้านี้)
  saleUnitName     String   @default("ชิ้น")
  purchaseUnitName String   @default("ชิ้น")
  reportUnitName   String   @default("ชิ้น")
  imageUrl         String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  aliases             ProductAlias[]
  carModels           ProductCarModel[]
  units               ProductUnit[]
  purchaseItems       PurchaseItem[]
  saleItems           SaleItem[]
  stockCards          StockCard[]
  warranties          Warranty[]
  adjustmentItems     AdjustmentItem[]
  creditNoteItems     CreditNoteItem[]
  purchaseReturnItems PurchaseReturnItem[]
}

// หน่วยนับของสินค้า — 1 สินค้า มีได้หลายหน่วย
// หน่วยหลัก (isBase = true) ต้องมี scale = 1 เสมอ
// หน่วยอื่นๆ scale คือจำนวนหน่วยย่อย (base units) ต่อ 1 หน่วยนั้น
// เช่น: ชิ้น (isBase, scale=1), โหล (scale=12), กล่อง (scale=6)
model ProductUnit {
  id        String   @id @default(cuid())
  productId String
  name      String
  scale     Float    // base unit scale = 1, โหล = 12, กล่อง = 6 ฯลฯ
  isBase    Boolean  @default(false)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
}

model ProductAlias {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  alias     String
  createdAt DateTime @default(now())

  @@unique([productId, alias])
  @@index([alias])
}

model ProductCarModel {
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  carModelId String
  carModel   CarModel @relation(fields: [carModelId], references: [id])

  @@id([productId, carModelId])
}

// ─────────────────────────────────────────
// Stock Card (บัตรสต็อกสินค้า)
// ─────────────────────────────────────────
// เป็น source of truth ของการเคลื่อนไหวสินค้า
// qty และ price ทั้งหมดอยู่ใน "หน่วยหลัก" (base unit, scale=1) ของสินค้านั้น
// ─────────────────────────────────────────

model StockCard {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  docNo        String          // เลขที่เอกสาร
  docDate      DateTime        // วันที่เอกสาร
  source       StockCardSource // แหล่งที่มา
  sorder       Int             // ลำดับ สำหรับเรียงภายในวันเดียวกันของสินค้าเดียวกัน
  qtyIn        Decimal         @default(0) @db.Decimal(12, 4) // จำนวนเข้า (base unit)
  qtyOut       Decimal         @default(0) @db.Decimal(12, 4) // จำนวนออก (base unit)
  qtyBalance   Decimal         @default(0) @db.Decimal(12, 4) // คงเหลือสะสม (base unit)
  landedCost   Decimal         @default(0) @db.Decimal(10, 2) // ค่าขนส่ง/ค่าแนบที่รวมใน avgCost
  priceIn      Decimal         @default(0) @db.Decimal(10, 4) // ราคาทุน/หน่วย ที่ซื้อเข้า (base unit)
  priceOut     Decimal         @default(0) @db.Decimal(10, 4) // avgCost ณ เวลาขายออก (base unit)
  priceBalance Decimal         @default(0) @db.Decimal(10, 4) // avgCost หลัง transaction นี้ (base unit)
  detail       String?         // รายละเอียด
  referenceId  String?         // อ้างอิง PurchaseItem.id / SaleItem.id / BF id ฯลฯ
  createdAt    DateTime        @default(now())

  @@index([productId, docDate, sorder])
  @@index([docNo])
}

enum StockCardSource {
  BF         // ยอดยกมา (Beginning Forward)
  PURCHASE   // ซื้อเข้า
  SALE       // ขายออก
  RETURN_IN  // รับคืนจากลูกค้า (CreditNote type=RETURN)
  RETURN_OUT // คืนสินค้าให้ซัพพลายเออร์ (PurchaseReturn)
  ADJUST_IN  // ปรับเพิ่ม (Adjustment)
  ADJUST_OUT // ปรับลด (Adjustment)
}

// ─────────────────────────────────────────
// Purchase (ซื้อสินค้าเข้า)
// ─────────────────────────────────────────

model Purchase {
  id          String         @id @default(cuid())
  purchaseNo  String         @unique
  supplierId  String?
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  totalAmount Decimal        @db.Decimal(10, 2)
  discount    Decimal        @default(0) @db.Decimal(10, 2)
  netAmount   Decimal        @db.Decimal(10, 2)
  note        String?
  purchaseDate DateTime      @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  items           PurchaseItem[]
  purchaseReturns PurchaseReturn[]
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  quantity    Int
  costPrice   Decimal  @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  landedCost  Decimal  @default(0) @db.Decimal(10, 2) // ค่าใช้จ่ายแนบ (ขนส่ง ฯลฯ) ต่อรายการ
}

// ─────────────────────────────────────────
// Customer (ลูกค้า)
// ─────────────────────────────────────────

model Customer {
  id              String   @id @default(cuid())
  code            String?  @unique  // รหัสลูกค้า เช่น C0001
  name            String
  phone           String?
  address         String?
  shippingAddress String?
  taxId           String?  // เลขผู้เสียภาษี
  note            String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]

  @@index([name])
}

// ─────────────────────────────────────────
// Sale (ขายสินค้า)
// ─────────────────────────────────────────

model Sale {
  id            String      @id @default(cuid())
  saleNo        String      @unique
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  customerName  String?     // fallback ถ้าไม่เลือกจาก Customer
  customerPhone String?
  saleType        SaleType        @default(RETAIL)
  paymentType     SalePaymentType @default(CASH_SALE)
  fulfillmentType FulfillmentType @default(PICKUP)
  shippingAddress String?
  shippingFee     Decimal?        @db.Decimal(10, 2)
  userId          String
  user          User        @relation(fields: [userId], references: [id])
  totalAmount   Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  netAmount     Decimal     @db.Decimal(10, 2)
  paymentMethod PaymentMethod? @default(CASH)
  note          String?
  saleDate      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         SaleItem[]
  warranties    Warranty[]
  creditNotes   CreditNote[]
}

enum SaleType {
  RETAIL    // ปลีก
  WHOLESALE // ส่ง
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  salePrice   Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  warranty    Warranty?
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT
}

// ─────────────────────────────────────────
// Warranty (ประกันสินค้า)
// ─────────────────────────────────────────

model Warranty {
  id            String    @id @default(cuid())
  saleId        String
  sale          Sale      @relation(fields: [saleId], references: [id])
  saleItemId    String    @unique
  saleItem      SaleItem  @relation(fields: [saleItemId], references: [id])
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  warrantyMonths Int
  startDate     DateTime
  endDate       DateTime
  note          String?
  createdAt     DateTime  @default(now())
}

// ─────────────────────────────────────────
// Expense (ค่าใช้จ่ายอื่นๆ)
// ─────────────────────────────────────────

model Expense {
  id          String      @id @default(cuid())
  category    ExpenseCategory
  description String
  amount      Decimal     @db.Decimal(10, 2)
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  expenseDate DateTime    @default(now())
  note        String?
  createdAt   DateTime    @default(now())
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARY
  TRANSPORT
  MARKETING
  MAINTENANCE
  OTHER
}

// ─────────────────────────────────────────
// Adjustment (ปรับสต็อก + / -)
// ─────────────────────────────────────────

model Adjustment {
  id         String           @id @default(cuid())
  adjustNo   String           @unique
  adjustDate DateTime         @default(now())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  items      AdjustmentItem[]
}

model AdjustmentItem {
  id           String     @id @default(cuid())
  adjustmentId String
  adjustment   Adjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  qtyAdjust    Decimal    @db.Decimal(12, 4) // + = เพิ่ม (ADJUST_IN), - = ลด (ADJUST_OUT) ใน base unit
  reason       String?    // เหตุผลการปรับ เช่น สินค้าเสียหาย, นับสต็อก
}

// ─────────────────────────────────────────
// Credit Note (CN ฝั่งขาย — เราออกให้ลูกค้า)
// ─────────────────────────────────────────

model CreditNote {
  id            String          @id @default(cuid())
  cnNo          String          @unique
  cnDate        DateTime        @default(now())
  saleId        String?         // อ้างอิงใบขายเดิม
  sale          Sale?           @relation(fields: [saleId], references: [id])
  customerName  String?
  customerPhone String?
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  type          CreditNoteType  // RETURN = คืนสินค้า (กระทบ stock), DISCOUNT = ลดราคา
  settlementType CNSettlementType @default(CASH_REFUND)
  totalAmount   Decimal         @db.Decimal(10, 2)
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         CreditNoteItem[]
}

model CreditNoteItem {
  id           String     @id @default(cuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?   @relation(fields: [productId], references: [id])
  qty          Decimal    @default(0) @db.Decimal(12, 4) // base unit (ใช้เมื่อ type=RETURN)
  unitPrice    Decimal    @default(0) @db.Decimal(10, 2) // ราคาขาย/หน่วย
  amount       Decimal    @default(0) @db.Decimal(10, 2) // จำนวนเงิน CN รายการนี้
  detail       String?
}

enum CreditNoteType {
  RETURN    // คืนสินค้า — กระทบ stock (RETURN_IN) + avgCost ไม่เปลี่ยน
  DISCOUNT  // ลดราคา — ไม่กระทบ stock
  OTHER     // อื่นๆ — ไม่กระทบ stock
}

enum SalePaymentType {
  CASH_SALE   // ขายสด
  CREDIT_SALE // ขายเชื่อ
}

enum CNSettlementType {
  CASH_REFUND  // คืนเป็นเงินสด
  CREDIT_DEBT  // ตั้งหนี้
}

// ─────────────────────────────────────────
// Purchase Return (คืนสินค้าให้ซัพพลายเออร์)
// ─────────────────────────────────────────

model PurchaseReturn {
  id          String               @id @default(cuid())
  returnNo    String               @unique
  returnDate  DateTime             @default(now())
  purchaseId  String?              // อ้างอิงใบซื้อเดิม
  purchase    Purchase?            @relation(fields: [purchaseId], references: [id])
  supplierId  String?
  supplier    Supplier?            @relation(fields: [supplierId], references: [id])
  userId      String
  user        User                 @relation(fields: [userId], references: [id])
  totalAmount Decimal              @db.Decimal(10, 2)
  note        String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  items       PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id               String         @id @default(cuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  qty              Decimal        @db.Decimal(12, 4) // base unit — กระทบ stock (RETURN_OUT)
  costPrice        Decimal        @db.Decimal(10, 2) // ราคาทุน/หน่วย ที่คืน
  amount           Decimal        @db.Decimal(10, 2)
  detail           String?
}

// ─────────────────────────────────────────
// Site Content (สำหรับ Admin แก้ไขหน้าเว็บ)
// ─────────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
