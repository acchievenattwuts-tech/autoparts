generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Auth
// ─────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String
  username           String?   @unique
  email              String    @unique
  password           String
  role               Role      @default(STAFF)
  appRoleId          String?
  appRole            AppRole?  @relation(fields: [appRoleId], references: [id])
  mustChangePassword Boolean   @default(false)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sales            Sale[]
  purchases        Purchase[]
  expenses         Expense[]
  adjustments      Adjustment[]
  creditNotes      CreditNote[]
  purchaseReturns  PurchaseReturn[]
  receipts         Receipt[]
  balanceForwards  BalanceForward[]

  @@index([username])
  @@index([appRoleId])
}

enum Role {
  ADMIN
  STAFF
}

model LoginThrottle {
  key            String    @id
  failures       Int       @default(0)
  firstFailureAt DateTime?
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AppRole {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  isSystem    Boolean             @default(false)
  users       User[]
  permissions AppRolePermission[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Permission {
  id          String              @id @default(cuid())
  key         String              @unique
  group       String
  label       String
  description String?
  roles       AppRolePermission[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model AppRolePermission {
  appRoleId     String
  permissionId  String
  appRole       AppRole     @relation(fields: [appRoleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@id([appRoleId, permissionId])
  @@index([permissionId])
}

// ─────────────────────────────────────────
// Car / Category Master Data
// ─────────────────────────────────────────

model CarBrand {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  carModels CarModel[]
}

model CarModel {
  id         String    @id @default(cuid())
  name       String
  carBrandId String
  carBrand   CarBrand  @relation(fields: [carBrandId], references: [id])
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  products   ProductCarModel[]

  @@unique([name, carBrandId])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Supplier {
  id           String         @id @default(cuid())
  code         String?        @unique
  name         String         @unique
  contactName  String?
  phone        String?
  address      String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  purchases         Purchase[]
  purchaseItems     PurchaseItem[]
  purchaseReturns   PurchaseReturn[]
  preferredProducts Product[]       @relation("ProductPreferredSupplier")
  warrantyClaims    WarrantyClaim[]
}

// ─────────────────────────────────────────
// Parts Brand Master
// ─────────────────────────────────────────

model PartsBrand {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  products  Product[]
}

// ─────────────────────────────────────────
// Product
// ─────────────────────────────────────────

model Product {
  id               String      @id @default(cuid())
  code             String      @unique
  name             String
  description      String?
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])
  brandId          String?
  brand            PartsBrand? @relation(fields: [brandId], references: [id])
  shelfLocation    String?
  costPrice        Decimal  @default(0) @db.Decimal(10, 2)
  salePrice        Decimal  @default(0) @db.Decimal(10, 2)
  stock            Int      @default(0)   // ระบบจัดการเท่านั้น ไม่ให้ user ระบุ
  avgCost          Decimal  @default(0) @db.Decimal(10, 2) // ต้นทุนถั่วเฉลี่ยปัจจุบัน — อัปเดตทุกครั้งที่ PURCHASE_IN
  minStock         Int      @default(1)
  // หน่วยนับ — ระบุชื่อหน่วยที่ใช้ในแต่ละบริบท (ต้องตรงกับ ProductUnit.name ของสินค้านี้)
  saleUnitName     String   @default("ชิ้น")
  purchaseUnitName String   @default("ชิ้น")
  reportUnitName   String   @default("ชิ้น")
  warrantyDays     Int      @default(0)   // จำนวนวันประกันเริ่มต้น (0 = ไม่มีประกัน)
  imageUrl         String?
  preferredSupplierId  String?
  preferredSupplier    Supplier? @relation("ProductPreferredSupplier", fields: [preferredSupplierId], references: [id])
  // Lot Control
  isLotControl       Boolean        @default(false)
  requireExpiryDate  Boolean        @default(false)
  lotIssueMethod     LotIssueMethod @default(FIFO)
  allowExpiredIssue  Boolean        @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  aliases             ProductAlias[]
  carModels           ProductCarModel[]
  units               ProductUnit[]
  purchaseItems       PurchaseItem[]
  saleItems           SaleItem[]
  stockCards          StockCard[]
  warranties          Warranty[]
  adjustmentItems     AdjustmentItem[]
  creditNoteItems     CreditNoteItem[]
  purchaseReturnItems PurchaseReturnItem[]
  balanceForwards     BalanceForward[]
  lots                ProductLot[]
  lotBalances         LotBalance[]
}

// หน่วยนับของสินค้า — 1 สินค้า มีได้หลายหน่วย
// หน่วยหลัก (isBase = true) ต้องมี scale = 1 เสมอ
// หน่วยอื่นๆ scale คือจำนวนหน่วยย่อย (base units) ต่อ 1 หน่วยนั้น
// เช่น: ชิ้น (isBase, scale=1), โหล (scale=12), กล่อง (scale=6)
model ProductUnit {
  id        String   @id @default(cuid())
  productId String
  name      String
  scale     Float    // base unit scale = 1, โหล = 12, กล่อง = 6 ฯลฯ
  isBase    Boolean  @default(false)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
}

model ProductAlias {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  alias     String
  createdAt DateTime @default(now())

  @@unique([productId, alias])
  @@index([alias])
}

model ProductCarModel {
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  carModelId String
  carModel   CarModel @relation(fields: [carModelId], references: [id])

  @@id([productId, carModelId])
}

// ─────────────────────────────────────────
// Stock Card (บัตรสต็อกสินค้า)
// ─────────────────────────────────────────
// เป็น source of truth ของการเคลื่อนไหวสินค้า
// qty และ price ทั้งหมดอยู่ใน "หน่วยหลัก" (base unit, scale=1) ของสินค้านั้น
// ─────────────────────────────────────────

model StockCard {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  docNo        String          // เลขที่เอกสาร
  docDate      DateTime        // วันที่เอกสาร
  source       StockCardSource // แหล่งที่มา
  sorder       Int             // ลำดับ สำหรับเรียงภายในวันเดียวกันของสินค้าเดียวกัน
  qtyIn        Decimal         @default(0) @db.Decimal(12, 4) // จำนวนเข้า (base unit)
  qtyOut       Decimal         @default(0) @db.Decimal(12, 4) // จำนวนออก (base unit)
  qtyBalance   Decimal         @default(0) @db.Decimal(12, 4) // คงเหลือสะสม (base unit)
  landedCost   Decimal         @default(0) @db.Decimal(10, 2) // ค่าขนส่ง/ค่าแนบที่รวมใน avgCost
  priceIn      Decimal         @default(0) @db.Decimal(10, 4) // ราคาทุน/หน่วย ที่ซื้อเข้า (base unit)
  priceOut     Decimal         @default(0) @db.Decimal(10, 4) // avgCost ณ เวลาขายออก (base unit)
  priceBalance Decimal         @default(0) @db.Decimal(10, 4) // avgCost หลัง transaction นี้ (base unit)
  detail       String?         // รายละเอียด
  referenceId  String?         // อ้างอิง PurchaseItem.id / SaleItem.id / BF id ฯลฯ
  createdAt    DateTime        @default(now())
  lotMovements StockMovementLot[]

  @@index([productId, docDate, sorder])
  @@index([docNo])
}

enum StockCardSource {
  BF               // ยอดยกมา (Beginning Forward)
  PURCHASE         // ซื้อเข้า
  SALE             // ขายออก
  RETURN_IN        // รับคืนจากลูกค้า (CreditNote type=RETURN)
  RETURN_OUT       // คืนสินค้าให้ซัพพลายเออร์ (PurchaseReturn)
  ADJUST_IN        // ปรับเพิ่ม (Adjustment)
  ADJUST_OUT       // ปรับลด (Adjustment)
  CLAIM_RETURN_IN  // ลูกค้าเอาของเสียกลับมาที่ร้าน (WarrantyClaim)
  CLAIM_SEND_OUT   // ส่งของเสียไปให้ supplier (WarrantyClaim)
  CLAIM_RECV_IN    // รับสินค้ากลับจาก supplier (WarrantyClaim)
  CLAIM_REPLACE_OUT // ส่งสินค้าออกให้ลูกค้า (WarrantyClaim)
}

enum DocStatus {
  ACTIVE
  CANCELLED
}

// ─────────────────────────────────────────
// Balance Forward (ยอดยกมา — header document)
// ─────────────────────────────────────────

model BalanceForward {
  id              String    @id @default(cuid())
  docNo           String    @unique
  docDate         DateTime
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  unitName        String    // หน่วยที่ระบุตอนบันทึก
  qtyInBase       Decimal   @db.Decimal(12, 4) // จำนวนในหน่วยหลัก
  costPerBaseUnit Decimal   @db.Decimal(10, 4) // ต้นทุน/หน่วยหลัก
  note            String?
  status          DocStatus @default(ACTIVE)
  cancelledAt     DateTime?
  cancelNote      String?
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())

  @@index([productId])
  @@index([docDate])
}

// ─────────────────────────────────────────
// Purchase (ซื้อสินค้าเข้า)
// ─────────────────────────────────────────

model Purchase {
  id          String         @id @default(cuid())
  purchaseNo  String         @unique
  supplierId  String?
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  totalAmount Decimal        @db.Decimal(10, 2)
  discount    Decimal        @default(0) @db.Decimal(10, 2)
  netAmount   Decimal        @db.Decimal(10, 2)
  note        String?
  vatType       VatType @default(NO_VAT)
  vatRate       Decimal @default(0) @db.Decimal(5, 2)
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  vatAmount     Decimal @default(0) @db.Decimal(10, 2)
  referenceNo  String?  // เลขที่เอกสารอ้างอิง (ใบกำกับซัพพลายเออร์)
  amountRemain Decimal  @default(0) @db.Decimal(10, 2) // ยอดคงค้าง AP (สำหรับใช้ในอนาคต)
  status      DocStatus @default(ACTIVE)
  cancelledAt DateTime?
  cancelNote  String?
  purchaseDate DateTime      @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  items           PurchaseItem[]
  purchaseReturns PurchaseReturn[]
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  quantity    Int
  costPrice   Decimal  @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  landedCost  Decimal  @default(0) @db.Decimal(10, 2) // ค่าใช้จ่ายแนบ (ขนส่ง ฯลฯ) ต่อรายการ
  lotItems    PurchaseItemLot[]
}

// ─────────────────────────────────────────
// Customer (ลูกค้า)
// ─────────────────────────────────────────

model Customer {
  id              String   @id @default(cuid())
  code            String?  @unique  // รหัสลูกค้า เช่น C0001
  name            String
  phone           String?
  address         String?
  shippingAddress String?
  taxId           String?  // เลขผู้เสียภาษี
  note            String?
  isActive        Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales       Sale[]
  receipts    Receipt[]
  creditNotes CreditNote[]

  @@index([name])
}

// ─────────────────────────────────────────
// Sale (ขายสินค้า)
// ─────────────────────────────────────────

model Sale {
  id            String      @id @default(cuid())
  saleNo        String      @unique
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  customerName  String?     // fallback ถ้าไม่เลือกจาก Customer
  customerPhone String?
  saleType        SaleType        @default(RETAIL)
  paymentType     SalePaymentType @default(CASH_SALE)
  fulfillmentType FulfillmentType @default(PICKUP)
  shippingAddress String?
  shippingFee     Decimal?        @db.Decimal(10, 2)
  shippingStatus  ShippingStatus  @default(PENDING)
  shippingMethod  ShippingMethod  @default(NONE)
  trackingNo      String?
  userId          String
  user          User        @relation(fields: [userId], references: [id])
  totalAmount   Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  netAmount     Decimal     @db.Decimal(10, 2)
  paymentMethod PaymentMethod? @default(CASH)
  note          String?
  vatType       VatType @default(NO_VAT)
  vatRate       Decimal @default(0) @db.Decimal(5, 2)
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  vatAmount     Decimal @default(0) @db.Decimal(10, 2)
  amountRemain  Decimal @default(0) @db.Decimal(10, 2) // ยอดคงค้าง AR = netAmount - รับชำระแล้ว
  status        DocStatus @default(ACTIVE)
  cancelledAt   DateTime?
  cancelNote    String?
  saleDate      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         SaleItem[]
  warranties    Warranty[]
  creditNotes   CreditNote[]
  receipts      ReceiptItem[]
}

enum SaleType {
  RETAIL    // ปลีก
  WHOLESALE // ส่ง
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum ShippingStatus {
  PENDING          // รอจัดส่ง
  OUT_FOR_DELIVERY // กำลังส่ง
  DELIVERED        // ส่งแล้ว
}

enum ShippingMethod {
  NONE  // ไม่ระบุ
  SELF  // ส่งเอง
  KERRY // Kerry
  FLASH // Flash
  JT    // J&T
  OTHER // อื่นๆ
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  salePrice   Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  warrantyDays   Int     @default(0)   // จำนวนวันประกันที่บันทึกตอนขาย (0 = ไม่มีประกัน)
  supplierId     String?
  supplierName   String?              // snapshot ณ วันขาย
  warranties     Warranty[]
  lotItems       SaleItemLot[]
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT
}

// ─────────────────────────────────────────
// Warranty (ประกันสินค้า)
// ─────────────────────────────────────────

model Warranty {
  id            String    @id @default(cuid())
  saleId        String
  sale          Sale      @relation(fields: [saleId], references: [id])
  saleItemId    String
  saleItem      SaleItem  @relation(fields: [saleItemId], references: [id])
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  unitSeq       Int       @default(1)  // ลำดับที่ของหน่วยใน SaleItem (qty=3 → unitSeq 1,2,3)
  warrantyDays  Int
  startDate     DateTime
  endDate       DateTime
  note          String?
  createdAt     DateTime  @default(now())
  claims        WarrantyClaim[]
  @@unique([saleItemId, unitSeq])
  @@index([productId])
  @@index([endDate])
}

// ─────────────────────────────────────────
// WarrantyClaim (ใบเคลมสินค้า)
// ─────────────────────────────────────────

model WarrantyClaim {
  id              String              @id @default(cuid())
  claimNo         String              @unique  // WC{YYMM}{4-digit}
  warrantyId      String
  warranty        Warranty            @relation(fields: [warrantyId], references: [id])
  claimDate       DateTime
  claimType       ClaimType           // REPLACE_NOW | CUSTOMER_WAIT
  status          WarrantyClaimStatus @default(DRAFT)
  outcome         ClaimOutcome?       // set เมื่อ CLOSED
  symptom         String?             // อาการที่ลูกค้าแจ้ง
  note            String?
  // Supplier snapshot ณ วันส่งเคลม
  supplierId      String?
  supplier        Supplier?           @relation(fields: [supplierId], references: [id])
  supplierName    String?
  supplierPhone   String?
  supplierAddress String?
  sentAt          DateTime?           // วันที่ส่ง supplier
  resolvedAt      DateTime?           // วันที่ปิดเคลม
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([warrantyId])
  @@index([claimDate])
  @@index([status])
}

enum WarrantyClaimStatus {
  DRAFT            // รับของเสียจากลูกค้า + ให้ของใหม่แล้ว (REPLACE_NOW) หรือรอ (CUSTOMER_WAIT)
  SENT_TO_SUPPLIER // ส่งของเสียไป supplier แล้ว
  CLOSED           // ปิดเคลม
  CANCELLED        // ยกเลิก
}

enum ClaimType {
  REPLACE_NOW   // เปลี่ยนของใหม่ให้ลูกค้าทันที (วันที่มาเคลม)
  CUSTOMER_WAIT // ลูกค้ารอ — ส่งให้เมื่อได้รับจาก supplier
}

enum ClaimOutcome {
  RECEIVED      // supplier ส่งของกลับมาแล้ว
  NO_RESOLUTION // supplier ปฏิเสธเคลม — ของเสียยังอยู่ที่ร้าน
}

// ─────────────────────────────────────────
// Expense Code (รหัสค่าใช้จ่าย — master)
// ─────────────────────────────────────────

model ExpenseCode {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  items       ExpenseItem[]
}

// ─────────────────────────────────────────
// Expense (ค่าใช้จ่ายอื่นๆ)
// ─────────────────────────────────────────

model Expense {
  id             String        @id @default(cuid())
  expenseNo      String        @unique
  expenseDate    DateTime
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  totalAmount    Decimal       @db.Decimal(10, 2)
  vatType        VatType       @default(NO_VAT)
  vatRate        Decimal       @default(0) @db.Decimal(5, 2)
  subtotalAmount Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(10, 2)
  netAmount      Decimal       @db.Decimal(10, 2)
  note           String?
  status         DocStatus     @default(ACTIVE)
  cancelledAt    DateTime?
  cancelNote     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          ExpenseItem[]
}

model ExpenseItem {
  id            String      @id @default(cuid())
  expenseId     String
  expense       Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseCodeId String
  expenseCode   ExpenseCode @relation(fields: [expenseCodeId], references: [id])
  description   String?
  amount        Decimal     @db.Decimal(10, 2)
}

// ─────────────────────────────────────────
// Adjustment (ปรับสต็อก + / -)
// ─────────────────────────────────────────

model Adjustment {
  id          String           @id @default(cuid())
  adjustNo    String           @unique
  adjustDate  DateTime         @default(now())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  note        String?
  status      DocStatus @default(ACTIVE)
  cancelledAt DateTime?
  cancelNote  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       AdjustmentItem[]
}

model AdjustmentItem {
  id           String     @id @default(cuid())
  adjustmentId String
  adjustment   Adjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  qtyAdjust    Decimal    @db.Decimal(12, 4) // + = เพิ่ม (ADJUST_IN), - = ลด (ADJUST_OUT) ใน base unit
  reason       String?    // เหตุผลการปรับ เช่น สินค้าเสียหาย, นับสต็อก
}

// ─────────────────────────────────────────
// Credit Note (CN ฝั่งขาย — เราออกให้ลูกค้า)
// ─────────────────────────────────────────

model CreditNote {
  id            String          @id @default(cuid())
  cnNo          String          @unique
  cnDate        DateTime        @default(now())
  saleId        String?         // อ้างอิงใบขายเดิม
  sale          Sale?           @relation(fields: [saleId], references: [id])
  customerId    String?
  customer      Customer?       @relation(fields: [customerId], references: [id])
  customerName  String?
  customerPhone String?
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  type          CreditNoteType  // RETURN = คืนสินค้า (กระทบ stock), DISCOUNT = ลดราคา
  settlementType CNSettlementType @default(CASH_REFUND)
  refundMethod  CNRefundMethod? // ใช้เมื่อ settlementType=CASH_REFUND
  totalAmount   Decimal         @db.Decimal(10, 2)
  note          String?
  vatType       VatType @default(NO_VAT)
  vatRate       Decimal @default(0) @db.Decimal(5, 2)
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  vatAmount     Decimal @default(0) @db.Decimal(10, 2)
  amountRemain  Decimal          @default(0) @db.Decimal(10, 2) // ยอดคงค้าง = totalAmount - รับชำระแล้ว (ใช้เมื่อ settlementType=CREDIT_DEBT)
  status        DocStatus @default(ACTIVE)
  cancelledAt   DateTime?
  cancelNote    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         CreditNoteItem[]
  receiptItems  ReceiptItem[]
}

model CreditNoteItem {
  id           String     @id @default(cuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?   @relation(fields: [productId], references: [id])
  qty          Decimal    @default(0) @db.Decimal(12, 4) // base unit (ใช้เมื่อ type=RETURN)
  unitPrice    Decimal    @default(0) @db.Decimal(10, 2) // ราคาขาย/หน่วย
  amount       Decimal    @default(0) @db.Decimal(10, 2) // จำนวนเงิน CN รายการนี้
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  detail       String?
  lotItems     CreditNoteItemLot[]
}

enum CreditNoteType {
  RETURN    // คืนสินค้า — กระทบ stock (RETURN_IN) + avgCost ไม่เปลี่ยน
  DISCOUNT  // ลดราคา — ไม่กระทบ stock
  OTHER     // อื่นๆ — ไม่กระทบ stock
}

enum SalePaymentType {
  CASH_SALE   // ขายสด
  CREDIT_SALE // ขายเชื่อ
}

enum CNSettlementType {
  CASH_REFUND  // คืนเป็นเงินสด
  CREDIT_DEBT  // ตั้งหนี้
}

enum CNRefundMethod {
  CASH     // เงินสด
  TRANSFER // โอนเงิน
}

// ─────────────────────────────────────────
// Purchase Return (คืนสินค้าให้ซัพพลายเออร์)
// ─────────────────────────────────────────

model PurchaseReturn {
  id          String               @id @default(cuid())
  returnNo    String               @unique
  returnDate  DateTime             @default(now())
  purchaseId  String?              // อ้างอิงใบซื้อเดิม
  purchase    Purchase?            @relation(fields: [purchaseId], references: [id])
  supplierId  String?
  supplier    Supplier?            @relation(fields: [supplierId], references: [id])
  userId      String
  user        User                 @relation(fields: [userId], references: [id])
  totalAmount Decimal              @db.Decimal(10, 2)
  note        String?
  vatType       VatType @default(NO_VAT)
  vatRate       Decimal @default(0) @db.Decimal(5, 2)
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  vatAmount     Decimal @default(0) @db.Decimal(10, 2)
  status        DocStatus @default(ACTIVE)
  cancelledAt   DateTime?
  cancelNote    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  items       PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id               String         @id @default(cuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  qty              Decimal        @db.Decimal(12, 4) // base unit — กระทบ stock (RETURN_OUT)
  costPrice        Decimal        @db.Decimal(10, 2) // ราคาทุน/หน่วย ที่คืน
  amount           Decimal        @db.Decimal(10, 2)
  subtotalAmount   Decimal        @default(0) @db.Decimal(10, 2)
  detail           String?
  lotItems         PurchaseReturnItemLot[]
}

// ─────────────────────────────────────────
// Site Content (สำหรับ Admin แก้ไขหน้าเว็บ)
// ─────────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

enum VatType {
  NO_VAT        // ไม่มีภาษี
  EXCLUDING_VAT // ราคาไม่รวม VAT (VAT แยก)
  INCLUDING_VAT // ราคารวม VAT แล้ว
}

// ─────────────────────────────────────────
// Receipt (ใบเสร็จรับเงิน — รับชำระหนี้ขายเชื่อ)
// ─────────────────────────────────────────

model Receipt {
  id            String        @id @default(cuid())
  receiptNo     String        @unique
  receiptDate   DateTime      @default(now())
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  customerName  String?       // fallback
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  note          String?
  status        DocStatus @default(ACTIVE)
  cancelledAt   DateTime?
  cancelNote    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         ReceiptItem[]
}

model ReceiptItem {
  id          String      @id @default(cuid())
  receiptId   String
  receipt     Receipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  saleId      String?
  sale        Sale?       @relation(fields: [saleId], references: [id])
  cnId        String?
  creditNote  CreditNote? @relation(fields: [cnId], references: [id])
  paidAmount  Decimal     @db.Decimal(10, 2)

  @@index([saleId])
  @@index([cnId])
}

// ─────────────────────────────────────────
// Lot Control (Phase 5.5)
// ─────────────────────────────────────────

enum LotIssueMethod {
  FIFO   // First In First Out — เรียงตาม mfgDate ASC (เก่าก่อน)
  FEFO   // First Expired First Out — เรียงตาม expDate ASC (ใกล้หมดอายุก่อน)
  MANUAL // ผู้ใช้เลือกเองทั้งหมด
}

// ข้อมูล Lot ต่อสินค้า (สร้างเมื่อรับเข้าครั้งแรก)
model ProductLot {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id])
  lotNo          String    // เลขที่ Lot (กำหนดเอง หรือ auto-gen)
  purchaseItemId String?   // อ้างอิงบรรทัดใบซื้อที่รับเข้า (ถ้ามี)
  mfgDate        DateTime? // วันที่ผลิต (optional)
  expDate        DateTime? // วันหมดอายุ (required ถ้า requireExpiryDate=true)
  unitCost       Decimal   @db.Decimal(10, 4) // ต้นทุน/หน่วยหลัก ของ lot นี้
  createdAt      DateTime  @default(now())

  @@unique([productId, lotNo])
  @@index([productId, expDate])
}

// ยอดคงเหลือราย Lot (source of truth สำหรับ lot qty)
model LotBalance {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  lotNo      String
  qtyOnHand  Decimal  @default(0) @db.Decimal(12, 4) // คงเหลือใน base unit

  @@unique([productId, lotNo])
  @@index([productId])
}

// Movement ราย Lot — ผูกกับ StockCard row
model StockMovementLot {
  id          String    @id @default(cuid())
  stockCardId String
  stockCard   StockCard @relation(fields: [stockCardId], references: [id], onDelete: Cascade)
  lotNo       String
  qtyIn       Decimal   @default(0) @db.Decimal(12, 4)
  qtyOut      Decimal   @default(0) @db.Decimal(12, 4)
  unitCost    Decimal   @default(0) @db.Decimal(10, 4) // snapshot ต้นทุน ณ เวลา movement

  @@index([stockCardId])
  @@index([lotNo])
}

// Sub-rows Lot ต่อบรรทัดใบซื้อ
model PurchaseItemLot {
  id             String       @id @default(cuid())
  purchaseItemId String
  purchaseItem   PurchaseItem @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)
  lotNo          String
  qty            Decimal      @db.Decimal(12, 4) // จำนวนใน base unit
  unitCost       Decimal      @db.Decimal(10, 4) // ต้นทุน/หน่วยหลักของ lot นี้
  mfgDate        DateTime?
  expDate        DateTime?

  @@index([purchaseItemId])
}

// Sub-rows Lot ต่อบรรทัดใบขาย
model SaleItemLot {
  id         String   @id @default(cuid())
  saleItemId String
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  lotNo      String
  qty        Decimal  @db.Decimal(12, 4) // จำนวนใน base unit
  unitCost   Decimal  @db.Decimal(10, 4) // snapshot ต้นทุน ณ วันขาย

  @@index([saleItemId])
}

// Sub-rows Lot ต่อบรรทัดใบคืนซัพพลายเออร์ (ต้องอ้างอิง lot เดิมจากใบซื้อ)
model PurchaseReturnItemLot {
  id                   String             @id @default(cuid())
  purchaseReturnItemId String
  purchaseReturnItem   PurchaseReturnItem @relation(fields: [purchaseReturnItemId], references: [id], onDelete: Cascade)
  lotNo                String
  qty                  Decimal            @db.Decimal(12, 4)

  @@index([purchaseReturnItemId])
}

// Sub-rows Lot ต่อบรรทัด CN (รับคืนจากลูกค้า)
// isReturnLot=true → สร้าง RET-{lotNo} แยก (ของที่ไม่แน่ใจสภาพ)
model CreditNoteItemLot {
  id               String         @id @default(cuid())
  creditNoteItemId String
  creditNoteItem   CreditNoteItem @relation(fields: [creditNoteItemId], references: [id], onDelete: Cascade)
  lotNo            String
  qty              Decimal        @db.Decimal(12, 4)
  isReturnLot      Boolean        @default(false) // true = merge กลับ lot เดิม, false = สร้าง RET-lot ใหม่

  @@index([creditNoteItemId])
}
